brain_node:
  ros__parameters:
    llm_interval_sec: 7.0
    offboard_rate_hz: 10.0
    ollama_url: "http://localhost:11434"   # change to your Ollama server URL
    ollama_model: "qwen2.5:32b"           # or qwen2.5:7b, llama3.2, etc.

yolo_detector:
  ros__parameters:
    model_path: "yolov8n.pt"
    confidence_threshold: 0.5
    camera_topic: "/camera"
    skip_frames: 2
